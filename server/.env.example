# Makia 通知器 - 服务端环境变量样例
#
# 复制为 .env 并填入真实值后再启动。.env 文件不得提交到版本控制。
# 所有 token 仅以 Bearer header 传输；服务端只保存其 hash。

# HTTP 监听地址（容器内）。Docker 仅发布 127.0.0.1:8788:8788。
HTTP_ADDR=:8788

# 对外公网地址（仅用于配置/文档，生产固定为下方值）。
PUBLIC_BASE_URL=https://notice.makia98.com

# 下行 provider，MVP 固定为自托管 SSE。
DELIVERY_PROVIDER=self_hosted_sse

# SSE 注释心跳间隔（秒）。
SSE_HEARTBEAT_INTERVAL_SECONDS=30

# 受信代理地址（逗号分隔）。仅当直连对端在此集合内时，才读取
# X-Forwarded-Proto / X-Real-IP / X-Forwarded-For。
TRUSTED_PROXY_ADDRS=127.0.0.1,::1

# ---- bootstrap 凭据（必填）----
# 谁可以发送：webhook access token（用随机长串，例如 openssl rand -hex 32）。
# 占位值仅供格式参考，必须替换。
BOOTSTRAP_WEBHOOK_ACCESS_TOKEN=replace-with-random-webhook-token

# 接收端 ID（默认 phone-main）。
BOOTSTRAP_RECEIVER_ID=phone-main

# 接收端身份令牌：App 用于 SSE/test 鉴权（用随机长串）。
BOOTSTRAP_RECEIVER_IDENTITY_TOKEN=replace-with-random-identity-token

# bootstrap receiver 状态。
BOOTSTRAP_RECEIVER_ENABLED=true
BOOTSTRAP_RECEIVER_ALLOWLISTED=true

# ---- 存储 ----
# SQLite 数据库路径，自动创建父目录。
STORAGE_PATH=./data/notice.db

# 可选：token hash pepper。留空则使用纯 SHA-256；设置后使用 HMAC-SHA256。
TOKEN_HASH_PEPPER=

# ---- 限流（每分钟）----
RATE_LIMIT_PER_TOKEN_PER_MIN=60
RATE_LIMIT_PER_IP_PER_MIN=120
RATE_LIMIT_PER_RECEIVER_PER_MIN=60
